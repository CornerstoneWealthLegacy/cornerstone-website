rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, update, delete: if request.auth != null &&
        request.auth.token.email in ['arthur@cornerstonewealthlegacy.com','simp70@gmail.com'];
    }
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        request.auth.token.email in ['arthur@cornerstonewealthlegacy.com','simp70@gmail.com'];
    }
    match /attyMessages/{uid}/messages/{msgId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null &&
        request.auth.token.email in ['arthur@cornerstonewealthlegacy.com','simp70@gmail.com'];
    }
    // Collaborative sessions — host and client can both read/write
    match /collab/{sessionId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }
    // Staff list — attorney writes, staff reads their own record
    match /staff/{emailKey} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.email in ['arthur@cornerstonewealthlegacy.com','simp70@gmail.com'];
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}